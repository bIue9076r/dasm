Init:
HP = 0x64
HG = 0x64
STR HP 0x00	# [0x00] = Hp (100)
STR HG 0x01	# [0x00] = Hunger (100)
LDD A 0x00	# A = Start Screen

Main:
CAL Display
CAL Update
JMP Main

Display:
DIS		# Display Screen
RET

Update:
LDD A $0x00	# Check HP
JEQ 0x00 Exit
LDD A $0x01	# Check Hunger
JEQ 0x00 Exit
RET

Random:
SND 0xA0
RET

Exit:
HLT		# Do not Return
